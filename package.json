{
  "name": "openqa",
  "version": "0.0.4",
  "description": "AI-powered Browser automation using playwright mcp",
  "type": "module",
  "bin": {
    "openqa": "./src/cli/bin.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./bdd": "./src/bdd/index.js",
    "./bdd/playwright-bdd": "./src/bdd/playwright-bdd.js",
    "./bdd/cucumber": "./src/bdd/cucumber.js"
  },
  "keywords": [
    "claude",
    "agent",
    "playwright",
    "browser-automation",
    "ai",
    "testing",
    "mcp",
    "shared-context",
    "bdd",
    "cucumber",
    "gherkin",
    "behavior-driven-development"
  ],
  "author": "Gurvinder Dhillon",
  "homepage": "https://www.auto-browse.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/auto-browse/openqa.git"
  },
  "license": "MIT",
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@langchain/anthropic": "^1.1.3",
    "@langchain/core": "^1.1.0",
    "@langchain/google-genai": "^2.0.0",
    "@langchain/langgraph": "^1.0.1",
    "@langchain/mcp-adapters": "^1.0.0",
    "@langchain/openai": "^1.1.3",
    "@playwright/mcp": "^0.0.48",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "dotenv": "^17.2.3",
    "inquirer": "^9.3.8",
    "js-yaml": "^4.1.1",
    "langchain": "^1.1.1",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@playwright/test": "^1.57.0",
    "playwright-bdd": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "playwright-bdd": {
      "optional": true
    },
    "@cucumber/cucumber": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "playwright-bdd": "^8.4.1"
