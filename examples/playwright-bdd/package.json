{
  "name": "playwright-bdd-example",
  "version": "1.0.1",
  "description": "Example using iQuest with Playwright BDD tests",
  "type": "module",
  "scripts": {
    "bddgen": "bddgen",
    "test": "npm run bddgen && playwright test",
    "test:ui": "npm run bddgen && playwright test --ui",
    "test:headed": "npm run bddgen && playwright test --headed",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "@vsaripella/iquest": "file:../.."
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright-bdd": "^9.1.0",
    "typescript": "^5.7.2"
  }
}
