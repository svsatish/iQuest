# iQuest Configuration for CucumberJS Example
# Copy this file to .env and fill in your API keys

# ============================================
# Agent Configuration
# ============================================

# Agent type: 'claude' or 'langchain' (default: claude)
AGENT_TYPE=langchain

# Default AI provider for langchain agent: 'anthropic', 'openai', or 'google'
DEFAULT_PROVIDER=anthropic

# ============================================
# API Keys (required - choose one based on provider)
# ============================================

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (for GPT models)
# OPENAI_API_KEY=your_openai_api_key_here

# Google API Key (for Gemini models)
# GOOGLE_API_KEY=your_google_api_key_here

# ============================================
# Optional Model Configuration
# ============================================

# Default model (overrides provider-specific defaults)
# DEFAULT_MODEL=claude-sonnet-4-5

# Provider-specific model overrides
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OPENAI_MODEL=gpt-4o
# GOOGLE_MODEL=gemini-2.5-flash

# Recursion limit for LangGraph agent (default: 100)
# Increase this for complex multi-step browser automation tasks
# RECURSION_LIMIT=100

# ============================================
# Browser Configuration
# ============================================

# Run browser in headed mode (default: false)
# HEADLESS=false