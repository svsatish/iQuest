{
  "name": "playwright-bdd-onkernel-example",
  "version": "1.0.0",
  "description": "Example using openqa with Playwright BDD tests on OnKernel cloud browsers",
  "type": "module",
  "scripts": {
    "bddgen": "bddgen",
    "test": "npm run bddgen && playwright test",
    "test:ui": "npm run bddgen && playwright test --ui",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@onkernel/sdk": "^0.2.0",
    "dotenv": "^16.4.5",
    "openqa": "file:../.."
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.0.1",
    "@playwright/test": "^1.56.1",
    "playwright-bdd": "^8.4.1",
    "typescript": "^5.7.2"
  }
}
