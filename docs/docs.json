{
    "$schema": "https://mintlify.com/docs.json",
    "theme": "maple",
    "name": "OpenQA",
    "description": "Agent Harness for Browser Test Automation",
    "colors": {
        "primary": "#8b5cf6",
        "light": "#a78bfa",
        "dark": "#7c3aed"
    },
    "logo": {
        "light": "/assets/400x114.png",
        "dark": "/assets/400x114-NoBackground.png"
    },
    "favicon": "/assets/favicon.png",
    "navigation": {
        "groups": [
            {
                "group": "Documentation",
