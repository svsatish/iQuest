            }
        ],
        "primary": {
            "type": "github",
            "href": "https://github.com/openqa-labs/openqa"
        }
    },
    "footer": {
        "socials": {
            "github": "https://github.com/openqa-labs/openqa"
        }
    },
    "contextual": {
        "options": [
            "copy",
            "view",
            "chatgpt",
