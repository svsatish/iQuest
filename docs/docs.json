{
    "$schema": "https://mintlify.com/docs.json",
    "theme": "mint",
    "name": "OpenQA",
    "description": "Agent Harness for Browser Test Automation",
    "colors": {
        "primary": "#EB521E",
        "light": "#F07040",
        "dark": "#C94418"
    },
    "font": {
        "headings": {
            "family": "Libre Baskerville",
            "source": "google"
        },
        "body": {
            "family": "Manrope",
            "source": "google"
        }
    },
    "logo": {
        "light": "/assets/logo_light_mode.svg",
        "dark": "/assets/logo_dark_mode.svg"
    },
    "favicon": "/assets/favicon.svg",
    "navigation": {
        "groups": [
            {
                "group": "Documentation",
                "pages": [
                    "index",
                    "quickstart",
                    "how-it-works"
                ]
            }
        ]
    },
    "navbar": {
        "links": [
            {
                "label": "openqa.io",
                "href": "https://openqa.io"
            },
            {
                "label": "GitHub",
                "href": "https://github.com/svsatish/iQuest"
            },
            {
                "label": "npm",
                "href": "https://www.npmjs.com/package/iquest"
            }
        ],
        "primary": {
            "type": "github",
            "href": "https://github.com/svsatish/iQuest"
        }
    },
    "footer": {
        "socials": {
            "github": "https://github.com/svsatish/iQuest"
        }
    },
    "contextual": {
        "options": [
            "copy",
            "view",
            "chatgpt",
            "claude",
            "perplexity",
            "cursor",
            "vscode"
        ]
    }
}
